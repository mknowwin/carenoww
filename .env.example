# ── Server ────────────────────────────────────────────────────────────────────
PORT=5031
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# Docker: MongoDB runs inside the app container itself, as a single-node
# replica set (rs0) — required for change streams / multi-document transactions.
# Local dev (no Docker): mongodb://localhost:27017/carenoww
MONGODB_URI=mongodb://127.0.0.1:27017/carenoww?replicaSet=rs0

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_secure_random_string_min_32_chars
SUPERADMIN_JWT_SECRET=change_this_to_another_secure_random_string
SUPERADMIN_EMAIL=superadmin@carenoww.io
SUPERADMIN_PASSWORD=SuperAdmin@2026!

# ── AI (Anthropic) ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. Leave blank when Express serves the React
# build (same-origin). Example: CORS_ORIGIN=https://hms.yourdomain.com
CORS_ORIGIN=
