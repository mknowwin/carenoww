# ── Server ────────────────────────────────────────────────────────────────────
PORT=5031
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# Docker: use the service name "mongo" as the host
# Local dev: mongodb://localhost:27017/carenoww
MONGODB_URI=mongodb://mongo:27017/carenoww

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_secure_random_string_min_32_chars
SUPERADMIN_JWT_SECRET=change_this_to_another_secure_random_string
SUPERADMIN_EMAIL=superadmin@carenoww.io
SUPERADMIN_PASSWORD=SuperAdmin@2026!

# ── AI (Anthropic) ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. Leave blank when Express serves the React
# build (same-origin). Example: CORS_ORIGIN=https://hms.yourdomain.com
CORS_ORIGIN=

# ── Pharmacy Inventory ────────────────────────────────────────────────────────
# Set to "true" to enable FEFO stock deduction when a pharmacy order is dispensed.
# Leave blank / "false" during migration; enable once batch data (GRNs) are in place.
PHARMACY_DEDUCT_ON_DISPENSE=false
